# ==== sppo-tracker-backend — variáveis de ambiente (exemplo) ====
# Copie para `.env` e ajuste: `cp .env.example .env`
# A API de GPS do SPPO é PÚBLICA — não há credencial obrigatória.
# `.env` é ignorado pelo git e pelo build Docker (ver .dockerignore); só este
# `.env.example` é versionado. Defaults completos em docs/regras-de-negocio.md §8.

# --- Aplicação ---
SERVER_PORT=8090            # porta HTTP publicada no host (o container escuta 8080)
GPS_POLLING_ENABLED=true    # liga/desliga o worker de polling

# --- Postgres (histórico de desvio de rota via Flyway) ---
DB_NAME=sppotracker
DB_USER=sppotracker
DB_PASSWORD=troque-esta-senha   # troque em produção, mesmo sem exposição externa

# --- Hosts de Redis/Postgres ---
# No docker-compose já apontam para os serviços `redis`/`postgres`; descomente
# apenas se for rodar o backend fora do compose.
# REDIS_HOST=redis
# REDIS_PORT=6379
# DB_HOST=postgres
# DB_PORT=5432

# --- HTTPS opcional (overlay docker-compose.oracle.yml, perfil `tls`) ---
# DOMAIN=sppo.seu-dominio.com
# LETSENCRYPT_EMAIL=voce@exemplo.com

# --- Ajustes finos opcionais (defaults no código — ver §8) ---
# GPS_POLLING_FIXED_DELAY=60s
# GPS_POLLING_OVERLAP_WINDOW=90s
# GPS_STALE_POSITION_THRESHOLD=5m
# DADOS_RIO_REQUEST_TIME_ZONE=America/Sao_Paulo
